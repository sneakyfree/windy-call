# Windy Call service — example env file. Copy to .env and fill in.

# --- Identity ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8600

# --- Redis (D.2 rate limit / cost cap) ---
# REDIS_URL=redis://localhost:6379/0

# --- Eternitas integration ---
ETERNITAS_BASE_URL=https://api.eternitas.ai
ETERNITAS_JWKS_URL=https://api.eternitas.ai/.well-known/eternitas-keys
# Provision via eternitas /platforms/register or direct SQL. The plaintext
# api_key is shown ONCE on creation; store in lockbox.
# ETERNITAS_PLATFORM_API_KEY=et_plt_REPLACE_WITH_REAL_KEY
# ETERNITAS_WEBHOOK_SECRET=REPLACE_WITH_REAL_SECRET

# --- Twilio (D.1 SMS; voice in D.3) ---
# WindyFly trial creds in lockbox. Promote to paid pre-launch.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1...   (a Twilio number you own)
